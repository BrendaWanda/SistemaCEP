# =============================================================================
#  SIACEP — .gitignore
# =============================================================================

# Variables de entorno (contiene credenciales reales)
.env

# Uploads generados por el sistema
public/uploads/*
!public/uploads/.gitkeep

# Reportes generados
public/reportes/*
!public/reportes/.gitkeep

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Dependencias (si se usa Composer)
vendor/
composer.lock